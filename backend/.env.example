# Efferra backend — environment variables template
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite default for bootstrap; switch to PostgreSQL for full dev)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/efferra

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=Europe/Amsterdam
