# Efferra backend — environment variables template
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL (required for local development)
# Create the database first: createdb efferra
DATABASE_URL=postgres://efferra:efferra@localhost:5432/efferra

# Redis — used for Celery task queue (background jobs) in later phases
# Not required yet, but documented here for the agreed architecture.
# REDIS_URL=redis://localhost:6379/0

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=Europe/Amsterdam
